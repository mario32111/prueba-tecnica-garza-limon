<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - VeloPark</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            brand: { 50:'#eff6ff', 100:'#dbeafe', 200:'#bfdbfe', 500:'#3b82f6', 600:'#2563eb', 700:'#1d4ed8', 800:'#1e40af', 900:'#1e3a8a' },
            success: { 50:'#f0fdf4', 100:'#dcfce7', 500:'#22c55e', 600:'#16a34a', 700:'#15803d' },
            danger:  { 50:'#fef2f2', 100:'#fee2e2', 500:'#ef4444', 600:'#dc2626', 700:'#b91c1c' },
            warning: { 50:'#fffbeb', 100:'#fef3c7', 500:'#f59e0b', 600:'#d97706' },
            surface: { DEFAULT:'#ffffff', dark:'#1e293b' },
            bg:      { DEFAULT:'#f0f9ff', dark:'#0f172a' },
            fg:      { DEFAULT:'#0f172a', dark:'#f8fafc' },
            muted:   { DEFAULT:'#f1f5f9', dark:'#334155' },
            'muted-fg': { DEFAULT:'#64748b', dark:'#94a3b8' },
            border:  { DEFAULT:'#e2e8f0', dark:'#334155' },
          },
          fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] },
        }
      }
    }
  </script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script>
    if (localStorage.getItem('theme') === 'dark' ||
       (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    }
  </script>
</head>
<body class="bg-bg dark:bg-bg-dark text-fg dark:text-fg-dark font-sans min-h-screen">

  <!-- Navbar Desktop -->
  <nav class="hidden lg:flex fixed top-0 left-0 right-0 z-40 h-16 bg-surface dark:bg-surface-dark border-b border-border dark:border-border-dark items-center px-6 shadow-sm">
    <div class="flex items-center gap-3 mr-8">
      <svg viewBox="0 0 40 40" class="w-9 h-9">
        <rect width="40" height="40" rx="10" fill="#2563EB"/>
        <path d="M12 28 L12 16 Q12 12 16 12 L24 12 Q28 12 28 16 L28 20 Q28 24 24 24 L16 24 L16 28 Z" fill="white" opacity="0.9"/>
        <circle cx="14" cy="28" r="2" fill="white"/>
        <circle cx="26" cy="28" r="2" fill="white"/>
        <path d="M18 16 L22 16 Q24 16 24 18 L24 20 Q24 22 22 22 L18 22 Z" fill="#2563EB"/>
      </svg>
      <span class="text-lg font-bold text-fg dark:text-fg-dark">VeloPark</span>
    </div>
    <div class="flex items-center gap-1">
      <a href="/dashboard" class="px-3 py-2 rounded-lg text-sm font-medium bg-brand-50 dark:bg-brand-900/30 text-brand-700 dark:text-brand-400">Dashboard</a>
      <% if (user.role === 'admin') { %>
        <a href="/parking/reports" class="px-3 py-2 rounded-lg text-sm font-medium text-muted-fg dark:text-muted-fg-dark hover:bg-muted dark:hover:bg-muted-dark hover:text-fg dark:hover:text-fg-dark transition-colors">Reportes</a>
        <a href="/categories/list" class="px-3 py-2 rounded-lg text-sm font-medium text-muted-fg dark:text-muted-fg-dark hover:bg-muted dark:hover:bg-muted-dark hover:text-fg dark:hover:text-fg-dark transition-colors">Categorías</a>
        <a href="/users/list" class="px-3 py-2 rounded-lg text-sm font-medium text-muted-fg dark:text-muted-fg-dark hover:bg-muted dark:hover:bg-muted-dark hover:text-fg dark:hover:text-fg-dark transition-colors">Usuarios</a>
      <% } %>
    </div>
    <div class="ml-auto flex items-center gap-3">
      <button onclick="toggleTheme()" class="p-2 rounded-lg text-muted-fg dark:text-muted-fg-dark hover:bg-muted dark:hover:bg-muted-dark transition-colors cursor-pointer">
        <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        <svg class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
      </button>
      <span class="text-sm text-muted-fg dark:text-muted-fg-dark"><%= user.role === 'admin' ? 'Administrador' : 'Empleado' %></span>
      <a href="/auth/logout" class="flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium text-danger-600 dark:text-danger-500 hover:bg-danger-50 dark:hover:bg-danger-900/20 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        Salir
      </a>
    </div>
  </nav>

  <!-- Mobile Header -->
  <header class="lg:hidden fixed top-0 left-0 right-0 z-40 h-14 bg-surface dark:bg-surface-dark border-b border-border dark:border-border-dark flex items-center px-4 shadow-sm">
    <button onclick="toggleSidebar()" class="p-2 -ml-2 rounded-lg text-muted-fg dark:text-muted-fg-dark hover:bg-muted dark:hover:bg-muted-dark transition-colors cursor-pointer">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
    <div class="flex items-center gap-2 ml-3">
      <svg viewBox="0 0 40 40" class="w-7 h-7">
        <rect width="40" height="40" rx="10" fill="#2563EB"/>
        <path d="M12 28 L12 16 Q12 12 16 12 L24 12 Q28 12 28 16 L28 20 Q28 24 24 24 L16 24 L16 28 Z" fill="white" opacity="0.9"/>
        <circle cx="14" cy="28" r="2" fill="white"/>
        <circle cx="26" cy="28" r="2" fill="white"/>
        <path d="M18 16 L22 16 Q24 16 24 18 L24 20 Q24 22 22 22 L18 22 Z" fill="#2563EB"/>
      </svg>
      <span class="font-bold text-fg dark:text-fg-dark">VeloPark</span>
    </div>
    <div class="ml-auto flex items-center gap-2">
      <button onclick="toggleTheme()" class="p-2 rounded-lg text-muted-fg dark:text-muted-fg-dark hover:bg-muted dark:hover:bg-muted-dark transition-colors cursor-pointer">
        <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        <svg class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
      </button>
    </div>
  </header>

  <!-- Sidebar Overlay -->
  <div id="sidebarOverlay" class="lg:hidden fixed inset-0 z-40 bg-black/50 backdrop-blur-sm hidden opacity-0 transition-opacity duration-300" onclick="toggleSidebar()"></div>

  <!-- Sidebar Mobile -->
  <aside id="sidebar" class="lg:hidden fixed inset-y-0 left-0 z-50 w-72 bg-surface dark:bg-surface-dark border-r border-border dark:border-border-dark -translate-x-full transition-transform duration-300 ease-in-out">
    <div class="flex items-center justify-between p-4 border-b border-border dark:border-border-dark">
      <div class="flex items-center gap-2">
        <svg viewBox="0 0 40 40" class="w-8 h-8">
          <rect width="40" height="40" rx="10" fill="#2563EB"/>
          <path d="M12 28 L12 16 Q12 12 16 12 L24 12 Q28 12 28 16 L28 20 Q28 24 24 24 L16 24 L16 28 Z" fill="white" opacity="0.9"/>
          <circle cx="14" cy="28" r="2" fill="white"/>
          <circle cx="26" cy="28" r="2" fill="white"/>
          <path d="M18 16 L22 16 Q24 16 24 18 L24 20 Q24 22 22 22 L18 22 Z" fill="#2563EB"/>
        </svg>
        <span class="font-bold text-fg dark:text-fg-dark">VeloPark</span>
      </div>
      <button onclick="toggleSidebar()" class="p-2 rounded-lg text-muted-fg dark:text-muted-fg-dark hover:bg-muted dark:hover:bg-muted-dark transition-colors cursor-pointer">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <nav class="p-4 space-y-1">
      <a href="/dashboard" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium bg-brand-50 dark:bg-brand-900/30 text-brand-700 dark:text-brand-400">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Dashboard
      </a>
      <% if (user.role === 'admin') { %>
        <a href="/parking/reports" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-muted-fg dark:text-muted-fg-dark hover:bg-muted dark:hover:bg-muted-dark hover:text-fg dark:hover:text-fg-dark transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Reportes
        </a>
        <a href="/categories/list" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-muted-fg dark:text-muted-fg-dark hover:bg-muted dark:hover:bg-muted-dark hover:text-fg dark:hover:text-fg-dark transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
          Categorías
        </a>
        <a href="/users/list" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-muted-fg dark:text-muted-fg-dark hover:bg-muted dark:hover:bg-muted-dark hover:text-fg dark:hover:text-fg-dark transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          Usuarios
        </a>
      <% } %>
      <div class="pt-4 mt-4 border-t border-border dark:border-border-dark">
        <a href="/auth/logout" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-danger-600 dark:text-danger-500 hover:bg-danger-50 dark:hover:bg-danger-900/20 transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
          Cerrar Sesión
        </a>
      </div>
    </nav>
  </aside>

  <!-- Main Content -->
  <main class="pt-14 lg:pt-16 pb-8 px-4 lg:px-8">
    <div class="max-w-6xl mx-auto">

      <!-- Toast container -->
      <div id="messages" class="fixed top-20 right-4 z-50 space-y-2"></div>

      <!-- Registrar Entrada + Buscar -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
        <div class="lg:col-span-2 bg-surface dark:bg-surface-dark rounded-xl border border-border dark:border-border-dark shadow-sm p-6">
          <h2 class="text-lg font-semibold text-fg dark:text-fg-dark mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-600 dark:text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Registrar Entrada
          </h2>
          <form id="entryForm" class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
            <div>
              <label for="entryPlate" class="block text-sm font-medium text-fg dark:text-fg-dark mb-1.5">Placa</label>
              <input type="text" id="entryPlate" placeholder="ABC123" required
                class="w-full px-3 py-2.5 border border-border dark:border-border-dark rounded-lg bg-surface dark:bg-surface-dark text-fg dark:text-fg-dark placeholder-muted-fg dark:placeholder-muted-fg-dark focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-colors uppercase">
            </div>
            <div>
              <label for="entryCategory" class="block text-sm font-medium text-fg dark:text-fg-dark mb-1.5">Categoría</label>
              <select id="entryCategory" required
                class="w-full px-3 py-2.5 border border-border dark:border-border-dark rounded-lg bg-surface dark:bg-surface-dark text-fg dark:text-fg-dark focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-colors appearance-none">
                <option value="">Seleccionar...</option>
                <% categories.forEach(function(c) { %>
                  <option value="<%= c.id %>"><%= c.name %> ($<%= c.pricePerMinute %>/min)</option>
                <% }); %>
              </select>
            </div>
            <button type="submit" class="bg-success-600 hover:bg-success-700 text-white py-2.5 px-4 rounded-lg font-medium transition-colors shadow-sm cursor-pointer flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L7 21"/></svg>
              Registrar
            </button>
          </form>
        </div>

        <div class="bg-surface dark:bg-surface-dark rounded-xl border border-border dark:border-border-dark shadow-sm p-6">
          <h2 class="text-lg font-semibold text-fg dark:text-fg-dark mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-600 dark:text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            Buscar Vehículo
          </h2>
          <div class="flex gap-2">
            <input type="text" id="searchPlate" placeholder="Placa..."
              class="flex-1 px-3 py-2.5 border border-border dark:border-border-dark rounded-lg bg-surface dark:bg-surface-dark text-fg dark:text-fg-dark placeholder-muted-fg dark:placeholder-muted-fg-dark focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-colors uppercase">
            <button onclick="searchVehicle()" class="bg-brand-600 hover:bg-brand-700 text-white py-2.5 px-4 rounded-lg font-medium transition-colors shadow-sm cursor-pointer">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Vehículos Estacionados -->
      <div class="bg-surface dark:bg-surface-dark rounded-xl border border-border dark:border-border-dark shadow-sm">
        <div class="p-6 border-b border-border dark:border-border-dark">
          <h2 class="text-lg font-semibold text-fg dark:text-fg-dark flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-600 dark:text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
            Vehículos Estacionados
          </h2>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="bg-muted dark:bg-muted-dark">
                <th class="px-4 py-3 text-left text-xs font-semibold text-muted-fg dark:text-muted-fg-dark uppercase tracking-wider">Placa</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-muted-fg dark:text-muted-fg-dark uppercase tracking-wider">Categoría</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-muted-fg dark:text-muted-fg-dark uppercase tracking-wider">Entrada</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-muted-fg dark:text-muted-fg-dark uppercase tracking-wider">Tiempo</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-muted-fg dark:text-muted-fg-dark uppercase tracking-wider">Registrado por</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-muted-fg dark:text-muted-fg-dark uppercase tracking-wider">Acción</th>
              </tr>
            </thead>
            <tbody id="activeTableBody" class="divide-y divide-border dark:divide-border-dark">
              <% records.forEach(function(r) { %>
                <tr class="hover:bg-muted/50 dark:hover:bg-muted-dark/50 transition-colors">
                  <td class="px-4 py-3 text-sm font-mono font-medium text-fg dark:text-fg-dark"><%= r.plate %></td>
                  <td class="px-4 py-3 text-sm">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                      <%= r.category && r.category.name === 'Oficial' ? 'bg-purple-50 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400' :
                         r.category && r.category.name === 'Residente' ? 'bg-brand-50 dark:bg-brand-900/30 text-brand-700 dark:text-brand-400' :
                         'bg-danger-50 dark:bg-danger-900/30 text-danger-700 dark:text-danger-400' %>">
                      <%= r.category ? r.category.name : '' %>
                    </span>
                  </td>
                  <td class="px-4 py-3 text-sm text-muted-fg dark:text-muted-fg-dark"><%= new Date(r.entryTime).toLocaleString() %></td>
                  <td class="px-4 py-3 text-sm font-mono text-fg dark:text-fg-dark" data-entry="<%= new Date(r.entryTime).getTime() %>">--</td>
                  <td class="px-4 py-3 text-sm text-muted-fg dark:text-muted-fg-dark"><%= r.registeredByUser ? r.registeredByUser.name : '' %></td>
                  <td class="px-4 py-3 text-sm">
                    <button onclick="cobrar('<%= r.plate %>')" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-medium bg-danger-600 hover:bg-danger-700 text-white transition-colors cursor-pointer">
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      Cobrar
                    </button>
                  </td>
                </tr>
              <% }); %>
              <% if (!records || records.length === 0) { %>
                <tr>
                  <td colspan="6" class="px-4 py-12 text-center">
                    <svg class="w-12 h-12 mx-auto text-muted-fg/30 dark:text-muted-fg-dark/30 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
                    <p class="text-muted-fg dark:text-muted-fg-dark text-sm">No hay vehículos estacionados</p>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>

  <!-- Modal Cobro -->
  <div id="cobrarModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 dark:bg-black/70 backdrop-blur-sm">
    <div class="bg-surface dark:bg-surface-dark rounded-2xl shadow-xl p-6 max-w-md w-full mx-4 border border-border dark:border-border-dark">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-full bg-danger-50 dark:bg-danger-900/30 flex items-center justify-center">
          <svg class="w-5 h-5 text-danger-600 dark:text-danger-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h3 class="text-lg font-semibold text-fg dark:text-fg-dark">Confirmar Cobro</h3>
      </div>
      <p class="text-sm text-muted-fg dark:text-muted-fg-dark mb-2">¿Estás seguro de cobrar al vehículo <strong id="cobrarPlate" class="text-fg dark:text-fg-dark font-mono"></strong>?</p>
      <p class="text-sm text-muted-fg dark:text-muted-fg-dark mb-6">Se calculará automáticamente el costo según la tarifa de la categoría.</p>
      <div class="flex gap-3 justify-end">
        <button onclick="closeModal()" class="px-4 py-2 rounded-lg text-sm font-medium border border-border dark:border-border-dark text-fg dark:text-fg-dark hover:bg-muted dark:hover:bg-muted-dark transition-colors cursor-pointer">Cancelar</button>
        <button onclick="confirmCobrar()" class="px-4 py-2 rounded-lg text-sm font-medium bg-danger-600 hover:bg-danger-700 text-white transition-colors cursor-pointer">Confirmar Cobro</button>
      </div>
    </div>
  </div>

  <script>
    var AUTH_TOKEN = '<%- token %>';
    var API_KEY = 'test-api-key-2024';

    function toggleSidebar() {
      var sidebar = document.getElementById('sidebar');
      var overlay = document.getElementById('sidebarOverlay');
      sidebar.classList.toggle('-translate-x-full');
      if (sidebar.classList.contains('-translate-x-full')) {
        overlay.classList.add('opacity-0', 'pointer-events-none');
        overlay.classList.remove('opacity-100', 'pointer-events-auto');
      } else {
        overlay.classList.remove('hidden', 'opacity-0', 'pointer-events-none');
        overlay.classList.add('opacity-100', 'pointer-events-auto');
      }
    }

    function toggleTheme() {
      var html = document.documentElement;
      if (html.classList.contains('dark')) {
        html.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      } else {
        html.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
    }

    function updateTimers() {
      document.querySelectorAll('[data-entry]').forEach(function(td) {
        var entry = parseInt(td.getAttribute('data-entry'));
        var diff = Math.floor((Date.now() - entry) / 60000);
        var h = Math.floor(diff / 60);
        var m = diff % 60;
        td.textContent = h + 'h ' + m + 'm';
      });
    }
    setInterval(updateTimers, 10000);
    updateTimers();

    var currentPlate = '';

    function cobrar(plate) {
      currentPlate = plate;
      document.getElementById('cobrarPlate').textContent = plate;
      var modal = document.getElementById('cobrarModal');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    function closeModal() {
      var modal = document.getElementById('cobrarModal');
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      currentPlate = '';
    }

    function confirmCobrar() {
      if (!currentPlate) return;
      fetch('/api/v1/parking/exit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'api': API_KEY, 'Authorization': 'Bearer ' + AUTH_TOKEN },
        body: JSON.stringify({ plate: currentPlate }),
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        closeModal();
        showMessage('Cobro exitoso - Placa: ' + data.plate + ' | Minutos: ' + data.totalMinutes + ' | Total: $' + parseFloat(data.totalCost).toFixed(2), 'success');
        setTimeout(function() { location.reload(); }, 1500);
      })
      .catch(function() {
        closeModal();
        showMessage('Error al procesar el cobro', 'error');
      });
    }

    function searchVehicle() {
      var plate = document.getElementById('searchPlate').value.trim();
      if (!plate) return;
      fetch('/api/v1/parking/plate/' + plate, {
        headers: { 'api': API_KEY, 'Authorization': 'Bearer ' + AUTH_TOKEN },
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var tbody = document.getElementById('activeTableBody');
        if (data.length > 0) {
          tbody.innerHTML = data.map(function(r) {
            var catClass = r.category && r.category.name === 'Oficial' ? 'bg-purple-50 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400' :
              r.category && r.category.name === 'Residente' ? 'bg-brand-50 dark:bg-brand-900/30 text-brand-700 dark:text-brand-400' :
              'bg-danger-50 dark:bg-danger-900/30 text-danger-700 dark:text-danger-400';
            return '<tr class="hover:bg-muted/50 dark:hover:bg-muted-dark/50 transition-colors">' +
              '<td class="px-4 py-3 text-sm font-mono font-medium text-fg dark:text-fg-dark">' + r.plate + '</td>' +
              '<td class="px-4 py-3 text-sm"><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ' + catClass + '">' + (r.category ? r.category.name : '') + '</span></td>' +
              '<td class="px-4 py-3 text-sm text-muted-fg dark:text-muted-fg-dark">' + new Date(r.entryTime).toLocaleString() + '</td>' +
              '<td class="px-4 py-3 text-sm font-mono text-fg dark:text-fg-dark">' + (r.status === 'active' ? '<span data-entry="' + new Date(r.entryTime).getTime() + '">--</span>' : r.totalMinutes + ' min') + '</td>' +
              '<td class="px-4 py-3 text-sm text-muted-fg dark:text-muted-fg-dark">' + (r.registeredByUser ? r.registeredByUser.name : '') + '</td>' +
              '<td class="px-4 py-3 text-sm">' + (r.status === 'active' ? '<button onclick="cobrar(\'' + r.plate + '\')" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-xs font-medium bg-danger-600 hover:bg-danger-700 text-white transition-colors cursor-pointer"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>Cobrar</button>' : '<span class="text-success-600 dark:text-success-500 font-medium">$' + parseFloat(r.totalCost).toFixed(2) + '</span>') + '</td></tr>';
          }).join('');
          updateTimers();
        } else {
          tbody.innerHTML = '<tr><td colspan="6" class="px-4 py-12 text-center"><p class="text-muted-fg dark:text-muted-fg-dark text-sm">Sin resultados</p></td></tr>';
        }
      });
    }

    document.getElementById('entryForm').addEventListener('submit', function(e) {
      e.preventDefault();
      var plate = document.getElementById('entryPlate').value.trim();
      var categoryId = document.getElementById('entryCategory').value;
      if (!plate || !categoryId) return;
      fetch('/api/v1/parking/entry', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'api': API_KEY, 'Authorization': 'Bearer ' + AUTH_TOKEN },
        body: JSON.stringify({ plate: plate, categoryId: parseInt(categoryId) }),
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.statusCode) {
          showMessage(data.message || 'Error', 'error');
        } else {
          showMessage('Entrada registrada: ' + data.plate, 'success');
          document.getElementById('entryPlate').value = '';
          setTimeout(function() { location.reload(); }, 1000);
        }
      })
      .catch(function() { showMessage('Error al registrar entrada', 'error'); });
    });

    function showMessage(msg, type) {
      var container = document.getElementById('messages');
      var toast = document.createElement('div');
      toast.className = 'flex items-center gap-2 px-4 py-3 rounded-lg shadow-lg text-sm font-medium transition-all duration-300 ' +
        (type === 'success' ? 'bg-success-600 text-white' : 'bg-danger-600 text-white');
      toast.innerHTML = (type === 'success'
        ? '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L7 21"/></svg>'
        : '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>') +
        '<span>' + msg + '</span>';
      container.appendChild(toast);
      setTimeout(function() { toast.remove(); }, 4000);
    }
  </script>
</body>
</html>
